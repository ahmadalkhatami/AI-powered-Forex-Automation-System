{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Kestrel": {
    "Endpoints": {
      "Http8080": {
        "Url": "http://localhost:8080"
      },
      "Http5033": {
        "Url": "http://127.0.0.1:5033"
      }
    }
  },
  "Mifx": {
    "EnableExecution": true
  },
  "News": {
    "FeedUrl": "https://nfs.faireconomy.media/ff_calendar_thisweek.xml"
  },
  "Scalp": {
    "Enabled": false,
    "Symbol": "XAUUSD.m",
    "TickEndpoint": "tcp://127.0.0.1:5560",
    "CommandEndpoint": "tcp://127.0.0.1:5561",
    "BufferSize": 500,
    "RecordTicks": true,
    "ZThreshold": 2.0,
    "MaxConcurrentPositions": 3,
    "HoldTimeStopSeconds": 15,
    "TakeProfitPoints": 20,
    "StopLossPoints": 20,
    "SpreadVetoPoints": 5,
    "StdDevFloorPoints": 1.5
  }
}
